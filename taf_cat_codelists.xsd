				</xs:enumeration>
				<xs:enumeration value="3">
					<xs:annotation>
						<xs:documentation>Light engine (locomotive train)</xs:documentation>
					</xs:annotation>
				</xs:enumeration>
				<xs:enumeration value="4">
					<xs:annotation>
						<xs:documentation>Engineering train</xs:documentation>
					</xs:annotation>
				</xs:enumeration>
				<xs:enumeration value="5">
